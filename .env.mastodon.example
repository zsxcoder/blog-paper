# Mastodon Configuration
# Copy this file to .env.local and fill in your values

# Mastodon instance URL (e.g., mastodon.social)
NEXT_PUBLIC_MASTODON_INSTANCE=ech0.zhzsx.cn

# Your Mastodon account ID (numeric ID, not username)
# You can find this by visiting https://your-instance.social/api/v1/accounts/lookup?acct=yourusername
NEXT_PUBLIC_MASTODON_USER_ID=115732018075313174

# Optional: Your Mastodon API access token
# Generate this from your Mastodon account settings > Development > New application
# Leave empty if you only want to fetch public statuses
NEXT_PUBLIC_MASTODON_TOKEN=

# Optional: Filter statuses by tag
# Leave empty to show all statuses
NEXT_PUBLIC_MASTODON_TAG=

# Optional: Maximum number of statuses to show on initial load
# Leave empty or set to 0 to show all
NEXT_PUBLIC_MASTODON_SHOWN_MAX=20
